# Local development only — the judging harness injects these at runtime.
# NEVER bake a real .env into the Docker image.
FIREWORKS_API_KEY=your-api-key-here
FIREWORKS_BASE_URL=https://your-openai-compatible-endpoint/v1
ALLOWED_MODELS=qwen3.6-plus,qwen3.7-plus,minimax-m3,kimi-k2.7-code

# Optional overrides for local runs (defaults are /input and /output):
# INPUT_PATH=./input/tasks.json
# OUTPUT_PATH=./output/results.json
