# Local development only — the judging harness injects these at runtime.
# NEVER bake a real .env into the Docker image.
FIREWORKS_API_KEY=your-api-key-here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
ALLOWED_MODELS=minimax-m3,kimi-k2p7-code,gemma-4-31b-it,gemma-4-26b-a4b-it,gemma-4-31b-it-nvfp4

# Gemma models are on-demand on Fireworks: deploy them at
# https://app.fireworks.ai/models first. Set to false while testing with your
# own key if you have NOT deployed them (a 404 means "not deployed").
USE_GEMMA=false

# Local model (bundled GGUF weights, llama-cpp-python)
USE_LOCAL=true
LOCAL_MODEL_PATH=./models/model.gguf

# Optional overrides for local runs (defaults are /input and /output):
# INPUT_PATH=./input/tasks.json
# OUTPUT_PATH=./output/results.json
